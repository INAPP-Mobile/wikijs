# =============================================================================
# Wiki.js 2.x — Self-hosted Knowledge Base & Documentation Platform
# https://docs.requarks.io/i/getting-started/install/prerequisites/docker
# =============================================================================
#
# This template runs Wiki.js as a single Docker container alongside a sibling
# 'postgres' Railway service (see the postgres/ subdirectory). The DB_* values
# below MUST match the postgres service's POSTGRES_USER / POSTGRES_PASSWORD /
# POSTGRES_DB so a fresh deploy authenticates automatically.

# ---------------------------------------------------------------------------
# Database Configuration
# Wiki.js supports PostgreSQL, MySQL/MariaDB, SQL Server, and SQLite.
# This template uses the sibling PostgreSQL service over the internal network.
# ---------------------------------------------------------------------------

# Database engine: postgres, mysql, mssql, sqlite
DB_TYPE=postgres

# PostgreSQL connection settings (sibling 'postgres' Railway service)
DB_HOST=postgres.railway.internal
DB_PORT=5432
DB_NAME=wikijs
DB_USER=postgres
DB_PASS=postgres

# SQLite storage path (only used when DB_TYPE=sqlite)
DB_FILEPATH=/wiki/data/wikijs.db

# ---------------------------------------------------------------------------
# Server Configuration
# Port Wiki.js listens on. Railway injects PORT automatically.
# ---------------------------------------------------------------------------

PORT=3000

# ---------------------------------------------------------------------------
# Application Settings
# Display name shown in browser tab & UI
# ---------------------------------------------------------------------------

APP_NAME=Wiki.js
TIMEZONE=UTC
URL_BASE=https://${{RAILWAY_PUBLIC_DOMAIN}}
